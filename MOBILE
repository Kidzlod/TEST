-- Single optimized loop for ESP
RunService.RenderStepped:Connect(function()
    if not State.ESP_Enabled then return end
    local localHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            
            if head and hum and hrp and hum.Health > 0 then
                local espId = "ESP_" .. plr.Name
                local gui = ESP_Folder:FindFirstChild(espId)
                
                if not gui then
                    gui = Instance.new("BillboardGui")
                    gui.Name = espId
                    gui.AlwaysOnTop = true
                    gui.Size = UDim2.new(0, 200, 0, 50)
                    local lab = Instance.new("TextLabel", gui)
                    lab.Name = "Text"
                    lab.Size = UDim2.new(1, 0, 1, 0)
                    lab.BackgroundTransparency = 1
                    lab.Font = Enum.Font.GothamBold
                    lab.TextScaled = true
                    lab.TextStrokeTransparency = 0.4
                    gui.Parent = ESP_Folder
                end
                
                gui.Adornee = head
                if localHrp then
                    local dist = math.floor((localHrp.Position - hrp.Position).Magnitude)
                    gui.Text.TextColor3 = State.ESP_Color
                    gui.Text.Text = string.format("%s\n%d HP | %dm", plr.Name, math.floor(hum.Health), dist)
                end
            else
                local gui = ESP_Folder:FindFirstChild("ESP_" .. plr.Name)
                if gui then gui:Destroy() end
            end
        end
    end
end)

Players.PlayerRemoving:Connect(function(plr)
