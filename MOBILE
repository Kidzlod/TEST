-- Heartbeat is much safer for physics parts than RenderStepped
RunService.Heartbeat:Connect(function()
    if State.HitboxEnabled then
        local targetSize = Vector3.new(State.HeadSize, State.HeadSize, State.HeadSize)
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp and hrp.Size ~= targetSize then
                    hrp.Size = targetSize
                    hrp.Transparency = 0.7
                    hrp.BrickColor = BrickColor.new("Cyan")
                    hrp.Material = Enum.Material.Neon
                    hrp.CanCollide = false
                end
            end
        end
    end
end)

